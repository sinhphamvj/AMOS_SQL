    <ds:dataSource xmlns:ds="http://www.swiss-as.com/xml/datasource_2.0" id="Form 539" type="SQL_EDITOR_DATASOURCE" version="2.0">
      <ds:description>CAAV Form 540</ds:description>
      <ds:columnDescriptors>
        <ds:columnDescriptor amosType="ALPHANUM" description="Firstname" id="s.firstname"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Lastname" id="s.lastname"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Sex" id="Sex"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Birthday" id="birthdate"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Phone No" id="phoneno"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Street" id="s.street"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="City" id="s.city"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Zipcode" id="s.zipcode"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Place Of Birthday" id="place_of_birth"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Nationality (vi du AUS)" id="nationality_code"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Nationality (vi du AUSTRALIA)" id="nationality"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="EMail" id="s.email"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Country code (vi du VN)" id="country_code"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Country (vi du VIETNAM)" id="country"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Street2" id="s.street2"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Zipcode2" id="s.zipcode2"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="City2" id="s.city2"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Country_code2 (vi du VN)" id="country_code2"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Country2 (vi du VIETNAM)" id="country2"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="CAAV AMT No" id="s.mech_stamp"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Other License" id="other_licenses"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="State Of License issue" id="licenses_state"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="License Issued Date" id="license_issued_date"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="License Expiry Date" id="license_exp_date"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="License Rating" id="licenses_rating"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Hair" id="hair"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Eyes" id="eyes"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Weight" id="uweight"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Height" id="uheight"/>
      </ds:columnDescriptors>
      <ds:configurationParameters/>
      <ds:sqlEditorDataSource>
        <se:sqlStatement xmlns:se="http://www.swiss-as.com/xml/sqlStatement_2.0" type="TEXT_EDITOR" version="2.0">
          <se:textStatement>SELECT 
    s.firstname,
    s.lastname,
    CASE 
        WHEN s.sex = 'M' THEN 'Male'
        WHEN s.sex = 'F' THEN 'Female'
    END AS Sex,
    TO_CHAR((DATE '1971-12-31' + s.birthdate)::DATE, 'DD.MON.YYYY') AS birthdate,
    MAX(CASE WHEN rpv.property_type_no_i = 178 THEN rpv.char_value END) AS phoneno,
    s.street,
    s.city,
    s.zipcode,
    MAX(CASE WHEN rpv.property_type_no_i = 2086 THEN rpv.char_value END) AS place_of_birth,
    s.nationality AS nationality_code,
    cn.description AS nationality,
    s.email,
    s.country AS country_code,
    cc.description AS country,
    s.street2,
    s.zipcode2,
    s.city2,
    s.country2 AS country_code2,
    cc.description AS country2,
    s.mech_stamp,
    COALESCE(s.mech_stamp, MAX(CASE WHEN rpv.property_type_no_i = 180 THEN rpv.char_value END)) AS other_licenses,
    MAX(CASE WHEN rpv.property_type_no_i = 2586 THEN rpv.char_value END) AS licenses_state,
    TO_CHAR((DATE '1971-12-31' + s.license_issue_date)::DATE, 'DD.MON.YYYY') AS license_issued_date,
    TO_CHAR((DATE '1971-12-31' + s.license_expiry_date)::DATE, 'DD.MON.YYYY') AS license_exp_date,
    MAX(CASE WHEN rpv.property_type_no_i = 2587 THEN rpv.char_value END) AS licenses_rating,
    MAX(CASE WHEN rpv.property_type_no_i = 2090 THEN rpv.char_value END) AS hair,
    MAX(CASE WHEN rpv.property_type_no_i = 2091 THEN rpv.char_value END) AS eyes,
    TO_CHAR(MAX(CASE WHEN rpv.property_type_no_i = 2089 THEN rpv.double_value END), 'FM999') AS uweight,
    TO_CHAR(MAX(CASE WHEN rpv.property_type_no_i = 2088 THEN rpv.int_value END), 'FM999') AS uheight
FROM sign s
LEFT JOIN rm_property_value rpv 
    ON s.employee_no_i = rpv.owner_amos_key
    AND rpv.owner_amos_type = 'SG'
LEFT JOIN country cn
    ON cn.country = s.nationality
LEFT JOIN country cc
    ON cc.country = s.country
WHERE
    s.user_sign='VJC2741'
GROUP BY s.employee_no_i, s.firstname, s.lastname, s.sex, s.birthdate,s.street,
         s.city, s.zipcode, s.nationality, cn.description, s.email, s.mech_stamp,
         s.country, cc.description, s.license_issue_date,s.street2, s.zipcode2, s.city2, s.country2,cc.description,s.license_expiry_date</se:textStatement>
        </se:sqlStatement>
      </ds:sqlEditorDataSource>
    </ds:dataSource>
  </dataSourceList>
</report>
