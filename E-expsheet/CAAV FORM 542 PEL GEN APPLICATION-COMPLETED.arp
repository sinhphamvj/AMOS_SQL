        <ds:columnDescriptor amosType="ALPHANUM" description="country2 (cho o hien tai)" id="country2"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="main skills" id="s.skill_shop"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Other_licenses" id="other_licenses"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="caav_license" id="caav_license"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="licenses_state" id="licenses_state"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="license_issued_date" id="license_issued_date"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="licenses_rating" id="licenses_rating"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="hair" id="hair"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Eyes" id="eyes"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Weight" id="uweight"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Height" id="uheight"/>
      </ds:columnDescriptors>
      <ds:configurationParameters>
        <ds:value amosType="ALPHANUM" description="string placeholder" id="@VAR.VJCID@">
          <ds:object>@VAR.VJCID@</ds:object>
        </ds:value>
      </ds:configurationParameters>
      <ds:sqlEditorDataSource>
        <se:sqlStatement xmlns:se="http://www.swiss-as.com/xml/sqlStatement_2.0" type="TEXT_EDITOR" version="2.0">
          <se:textStatement>SELECT 
    s.firstname,
    s.lastname,
    CASE 
        WHEN s.sex = 'M' THEN 'Male'
        WHEN s.sex = 'F' THEN 'Female'
    END AS Sex,
    TO_CHAR((DATE '1971-12-31' + s.birthdate)::DATE, 'DD.MON.YYYY') AS birthdate,
    MAX(CASE WHEN rpv.property_type_no_i = 178 THEN rpv.char_value END) AS phoneno,
    s.street,
    s.city,
    MAX(CASE WHEN rpv.property_type_no_i = 2086 THEN rpv.char_value END) AS place_of_birth,
    s.nationality AS nationality_code,
    cn.description AS nationality,
    s.email,
    s.country AS country_code,
    cc.description AS country,
    s.street2,
    s.zipcode2,
    s.city2,
    s.country2 AS country_code2,
    cc.description AS country2,
    s.skill_shop,
    COALESCE(s.mech_stamp, MAX(CASE WHEN rpv.property_type_no_i = 180 THEN rpv.char_value END)) AS other_licenses,
    s.mech_stamp AS caav_license,
    MAX(CASE WHEN rpv.property_type_no_i = 2586 THEN rpv.char_value END) AS licenses_state,
    TO_CHAR((DATE '1971-12-31' + s.license_issue_date)::DATE, 'DD.MON.YYYY') AS license_issued_date,
    MAX(CASE WHEN rpv.property_type_no_i = 2587 THEN rpv.char_value END) AS licenses_rating,
    MAX(CASE WHEN rpv.property_type_no_i = 2090 THEN rpv.char_value END) AS hair,
    MAX(CASE WHEN rpv.property_type_no_i = 2091 THEN rpv.char_value END) AS eyes,
    TO_CHAR(MAX(CASE WHEN rpv.property_type_no_i = 2089 THEN rpv.double_value END), 'FM999') AS uweight,
    TO_CHAR(MAX(CASE WHEN rpv.property_type_no_i = 2088 THEN rpv.int_value END), 'FM999') AS uheight
FROM sign s
LEFT JOIN rm_property_value rpv 
    ON s.employee_no_i = rpv.owner_amos_key
    AND rpv.owner_amos_type = 'SG'
LEFT JOIN country cn
    ON cn.country = s.nationality
LEFT JOIN country cc
    ON cc.country = s.country
WHERE
    s.user_sign='@VAR.VJCID@'
GROUP BY s.employee_no_i, s.firstname, s.lastname, s.sex, s.birthdate,s.street,
         s.city, s.nationality, cn.description, s.email, s.mech_stamp,
         s.country, cc.description, s.license_issue_date, s.skill_shop,s.street2, s.zipcode2, s.city2, s.country2,cc.description</se:textStatement>
        </se:sqlStatement>
      </ds:sqlEditorDataSource>
    </ds:dataSource>
  </dataSourceList>
</report>
