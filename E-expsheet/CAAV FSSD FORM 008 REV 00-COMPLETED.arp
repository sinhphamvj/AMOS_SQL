        <ds:columnDescriptor amosType="ALPHANUM" description="db_link.link_remarks" id="db_link.link_remarks"/>
      </ds:columnDescriptors>
      <ds:configurationParameters>
        <ds:value amosType="ALPHANUM" description="string placeholder" id="@LOGIN_SIGN@">
          <ds:object>@LOGIN_SIGN@</ds:object>
        </ds:value>
      </ds:configurationParameters>
      <ds:sqlEditorDataSource>
        <se:sqlStatement xmlns:se="http://www.swiss-as.com/xml/sqlStatement_2.0" type="TEXT_EDITOR" version="2.0">
                                                  
          
          
          
          <se:textStatement>SELECT
db_link.link_remarks
FROM db_link
