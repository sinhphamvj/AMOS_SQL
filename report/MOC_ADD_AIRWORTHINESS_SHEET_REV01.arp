  <dataSourceList>
    <ds:dataSource xmlns:ds="http://www.swiss-as.com/xml/datasource_2.0" id="VAR" type="PARAMETER_DATASOURCE" version="2.0">
      <ds:description>Contains all user defined variables and constants.</ds:description>
      <ds:columnDescriptors>
        <ds:columnDescriptor amosType="AC" description="Input Aircraft Registration here for extracting MEL" id="ACReg"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="Just a regular ordinary title for airwroth" id="TITLE"/>
      </ds:columnDescriptors>
      <ds:configurationParameters>
        <ds:value amosType="NONE" description="Aircraft Registration" id="ACReg">
          <ds:map>
            <ds:keyValuePair>
              <ds:key>mandatory</ds:key>
              <ds:data>true</ds:data>
            </ds:keyValuePair>
            <ds:keyValuePair>
              <ds:key>relativeDate</ds:key>
              <ds:data>false</ds:data>
            </ds:keyValuePair>
            <ds:keyValuePair>
              <ds:key>defaultValue</ds:key>
              <ds:data/>
            </ds:keyValuePair>
            <ds:keyValuePair>
              <ds:key>selectionValues</ds:key>
              <ds:data>*</ds:data>
            </ds:keyValuePair>
            <ds:keyValuePair>
              <ds:key>multi</ds:key>
              <ds:data>false</ds:data>
            </ds:keyValuePair>
          </ds:map>
        </ds:value>
        <ds:value amosType="NONE" description="Title" id="TITLE">
          <ds:map>
            <ds:keyValuePair>
              <ds:key>mandatory</ds:key>
              <ds:data>true</ds:data>
            </ds:keyValuePair>
