              <ds:data>AIRWORTHINESS ACCEPTABLE DEFERRED DEFECTS</ds:data>
            </ds:keyValuePair>
            <ds:keyValuePair>
              <ds:key>selectionValues</ds:key>
              <ds:data>*</ds:data>
            </ds:keyValuePair>
            <ds:keyValuePair>
              <ds:key>multi</ds:key>
              <ds:data>false</ds:data>
            </ds:keyValuePair>
          </ds:map>
        </ds:value>
      </ds:configurationParameters>
    </ds:dataSource>
    <ds:dataSource xmlns:ds="http://www.swiss-as.com/xml/datasource_2.0" id="MCC Open MEL per Aircraft" type="SQL_EDITOR_DATASOURCE" version="2.0">
      <ds:description>This table is for list of open MEL items per aircrafts. Airworthiness and not</ds:description>
            <ds:columnDescriptors>
        <ds:columnDescriptor amosType="ALPHANUM" description="wo_header.event_perfno_i" id="wo_header.event_perfno_i"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="wo_header.ext_workorderno" id="wo_header.ext_workorderno"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="mel_code2" id="mel_code2"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="wo_header_more.mel_chapter" id="wo_header_more.mel_chapter"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="tf_chk_ops_consequence" id="tf_chk_ops_consequence"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="add_type" id="add_type"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="description" id="description"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="lt_due_tac" id="lt_due_tac"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="lt_due_tah" id="lt_due_tah"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="lt_due_date" id="lt_due_date"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="pt_stn" id="pt_stn"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="pt_base_date" id="pt_base_date"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="pt_name_last" id="pt_name_last"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="pt_name_first" id="pt_name_first"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="tlop_description" id="tlop_description"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="add_description" id="add_description"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="rep_maint_desc" id="rep_maint_desc"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="wo_rep_maint_desc" id="wo_rep_maint_desc"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="doc_ref_description" id="doc_ref_description"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="mp_description" id="mp_description"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="ops_description" id="ops_description"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="mp_wo_text_event_perfno_i" id="mp_wo_text_event_perfno_i"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="ops_proc_wo_text_event_perfno_i" id="ops_proc_wo_text_event_perfno_i"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="doc_ref_ws_ref_type" id="doc_ref_ws_ref_type"/>
        <ds:columnDescriptor amosType="ALPHANUM" description="doc_ref_ws_description" id="doc_ref_ws_description"/>
      </ds:columnDescriptors>
      <ds:configurationParameters>
        <ds:value amosType="ALPHANUM" description="string placeholder" id="@ACReg@">
          <ds:object>@ACReg@</ds:object>
        </ds:value>
      </ds:configurationParameters>
      <ds:sqlEditorDataSource>
        <se:sqlStatement xmlns:se="http://www.swiss-as.com/xml/sqlStatement_2.0" type="TEXT_EDITOR" version="2.0">
                    <se:textStatement>WITH 
ref_details AS (
    SELECT 
        source_pk,
        MAX(CASE WHEN ref_type = 'TLOP' THEN UPPER(description) END) AS tlop_description,
        MAX(CASE WHEN ref_type = 'ADD' THEN UPPER(description) END) AS add_description,
        MAX(CASE WHEN ref_type = 'ADD' THEN UPPER(link_remarks) END) AS link_remarks,
        MAX(CASE WHEN ref_type = 'REP_MNT' THEN UPPER(description) END) AS rep_maint_desc,
        MAX(CASE WHEN ref_type = 'WO' AND link_remarks = 'REPETITIVE INSPECTION' THEN UPPER(description) END) AS wo_rep_maint_desc,
        MAX(CASE WHEN ref_type = 'DOC_REF' THEN UPPER(description) END) AS doc_ref_description,
        MAX(CASE WHEN ref_type = 'MP' THEN UPPER(description) END) AS mp_description,
        MAX(CASE WHEN ref_type = 'OPS' THEN UPPER(description) END) AS ops_description,
        MAX(CASE WHEN ref_type = 'OPSLIMIT' THEN UPPER(description) END) AS opslimit_description,
        MAX(CASE WHEN ref_type = 'REP_MNT' THEN CAST(source_pk AS INT) END) AS source_no
    FROM db_link
    WHERE source_type = 'WO'
    GROUP BY source_pk
),
latest_transfer AS (
    SELECT 
        event_perfno_i AS wo_no,
        MAX(CASE 
                WHEN dimension = 'C' 
                THEN absolute_due_at_ac::INT 
            END) AS lt_due_tac,
        MAX(CASE 
                WHEN dimension = 'H' 
                THEN TO_CHAR(
                        (absolute_due_at_ac || ' minutes')::interval,
                        'HH24:MI'
                     )
            END) AS lt_due_tah,
        MAX(CASE 
                WHEN dimension = 'D' 
                THEN TO_CHAR(
                        DATE '1971-12-31' + expected_date,
                        'DD MON YYYY'
                     )
            END) AS lt_due_date
    FROM forecast_dimension
    GROUP BY event_perfno_i
),
pref_transfer_ranked AS (
    SELECT 
        wo_transfer.event_perfno_i AS wo_no,
        wo_transfer.transfer_station AS pt_stn,
        TO_CHAR(COALESCE(DATE '1971-12-31' + wo_transfer.baseline_date, DATE '1971-12-31' + wo_transfer.date_transfer), 'DD MON YYYY') AS pt_base_date,
        TO_CHAR(DATE '1971-12-31' + wo_transfer.date_transfer, 'DD MON YYYY') AS pt_date,
        sign.lastname AS pt_name_last,
        sign.firstname AS pt_name_first,
        sign.auth_number AS pt_auth_no,
        ROW_NUMBER() OVER (PARTITION BY wo_transfer.event_perfno_i ORDER BY wo_transfer.date_transfer ASC) AS rn
    FROM wo_transfer
    LEFT JOIN sign ON wo_transfer.user_sign = sign.user_sign
    WHERE wo_transfer.transfer_type = 'T'
),
pref_transfer AS (
    SELECT * FROM pref_transfer_ranked WHERE rn = 1
),
mp_text_check AS (
    SELECT DISTINCT event_perfno_i
    FROM wo_text_action
    WHERE text LIKE ANY (ARRAY['%MAINT PROC%', '%MAINTENANCE PROCEDURE%', '%MAINT PROCEDURE%', '%MAINTENANCE PROC%'])
),
ops_text_check AS (
    SELECT DISTINCT event_perfno_i
    FROM wo_text_action
    WHERE text LIKE '%OPERATIONS PROCEDURE%' OR text LIKE '%OPS PROC%'
),
doc_ref_ws_ranked AS (
    SELECT 
        wo_text_action.event_perfno_i AS wo_no,
        db_link.ref_type,
        db_link.description,
        ROW_NUMBER() OVER (PARTITION BY wo_text_action.event_perfno_i ORDER BY wo_text_action.actionno_i ASC) AS rn
    FROM wo_text_action
    JOIN db_link ON wo_text_action.actionno_i::VARCHAR = db_link.source_pk
    WHERE db_link.source_type = 'WOA'
      AND db_link.ref_type IN ('MEL','AMM','CDL','SRM','NTM','TSM','DOC_REF')
),
doc_ref_ws AS (
    SELECT * FROM doc_ref_ws_ranked WHERE rn = 1
)
SELECT     
       wo_header.event_perfno_i AS "wo_header.event_perfno_i",
       wo_header.ext_workorderno AS "wo_header.ext_workorderno",
       CASE wo_header.mel_code WHEN 'L' THEN 'N/A' ELSE wo_header.mel_code END AS mel_code2,
       wo_header_more.mel_chapter AS "wo_header_more.mel_chapter",
       COALESCE(wo_header_4.chk_ops_consequence,'N') AS tf_chk_ops_consequence,
       CASE wo_header.mel_code WHEN 'L' THEN 'CDL' WHEN 'A' THEN 'MEL' WHEN 'B' THEN 'MEL' WHEN 'C' THEN 'MEL' WHEN 'D' THEN 'MEL' ELSE '' END as add_type,
       wo_text_description.text AS description,
       
       latest_transfer.lt_due_tac,
       latest_transfer.lt_due_tah,
       latest_transfer.lt_due_date,
       
       pref_transfer.pt_stn,
       pref_transfer.pt_base_date,
       pref_transfer.pt_name_last,
       pref_transfer.pt_name_first,
       
       ref_details.tlop_description,
       ref_details.add_description,
       ref_details.rep_maint_desc,
       ref_details.wo_rep_maint_desc,
       ref_details.doc_ref_description,
       ref_details.mp_description,
       ref_details.ops_description,
       
       mp_text_check.event_perfno_i AS mp_wo_text_event_perfno_i,
       
       ops_text_check.event_perfno_i AS ops_proc_wo_text_event_perfno_i,
       
       doc_ref_ws.ref_type AS doc_ref_ws_ref_type,
       doc_ref_ws.description AS doc_ref_ws_description

FROM wo_header              
LEFT JOIN wo_header_more ON wo_header.event_perfno_i = wo_header_more.event_perfno_i 
LEFT JOIN wo_header_4 ON wo_header.event_perfno_i = wo_header_4.event_perfno_i                               
LEFT JOIN workstep_link ON workstep_link.event_perfno_i = wo_header.event_perfno_i 
                       AND workstep_link.sequenceno = (SELECT MAX(sequenceno) FROM workstep_link wl WHERE wl.event_perfno_i = wo_header.event_perfno_i)
LEFT JOIN wo_text_description ON wo_text_description.descno_i = workstep_link.descno_i                
LEFT JOIN ref_details ON ref_details.source_pk = wo_header.event_perfno_i::VARCHAR
LEFT JOIN latest_transfer ON latest_transfer.wo_no = wo_header.event_perfno_i
LEFT JOIN pref_transfer ON pref_transfer.wo_no = wo_header.event_perfno_i
LEFT JOIN mp_text_check ON mp_text_check.event_perfno_i = wo_header.event_perfno_i
LEFT JOIN ops_text_check ON ops_text_check.event_perfno_i = wo_header.event_perfno_i
LEFT JOIN doc_ref_ws ON doc_ref_ws.wo_no = wo_header.event_perfno_i

WHERE wo_header.ac_registr = '@ACReg@'
      AND wo_header.state = 'O'  
      AND wo_header.type IN ('M','P','C')                                                                            
      AND wo_header_more.wo_class IN  (
         'A',
         'L',
         'T'                                                        
      )                                                         
      AND (wo_text_description.text IS NULL OR wo_text_description.text NOT LIKE '%REPETITIVE INSPECTION FOR%')
ORDER BY wo_header.issue_date,
         wo_header.event_perfno_i</se:textStatement>
        </se:sqlStatement>
      </ds:sqlEditorDataSource>
    </ds:dataSource>
  </dataSourceList>
</report>
